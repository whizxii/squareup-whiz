# SquareUp Comms Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────
# SQLite for local dev (default). docker-compose overrides to PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ── General ───────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO

# ── Auth ──────────────────────────────────────────────────────
# Set to false in production to require real Firebase tokens.
ENABLE_DEV_AUTH=true

# ── Firebase ──────────────────────────────────────────────────
# Option A: Paste the full JSON string of your service account key
FIREBASE_CREDENTIALS_JSON=
# Option B: Path to the JSON file (used when FIREBASE_CREDENTIALS_JSON is empty)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Google OAuth (Calendar + Gmail) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback

# ── Gmail Sync ────────────────────────────────────────────────
GMAIL_SYNC_ENABLED=false
GMAIL_SYNC_INTERVAL_SECONDS=300

# ── LLM Provider (Groq — free tier) ──────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ── Anthropic (optional, for premium agent responses) ─────────
ANTHROPIC_API_KEY=

# ── LiveKit (voice / video calls) ─────────────────────────────
# Get free credentials at https://cloud.livekit.io
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Supabase (Database + Storage) ─────────────────────────────
# Get these from your Supabase project settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── File Storage ──────────────────────────────────────────────
FIREBASE_STORAGE_BUCKET=

# ── Email Tracking ────────────────────────────────────────────
EMAIL_TRACKING_BASE_URL=http://localhost:8000/api/crm/v2

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Encryption ────────────────────────────────────────────────
# Fernet key for encrypting OAuth tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
