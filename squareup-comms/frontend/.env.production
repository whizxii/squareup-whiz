# Production environment — Vercel deployment

NEXT_PUBLIC_API_URL=https://squareup-whiz.onrender.com
NEXT_PUBLIC_WS_URL=wss://squareup-whiz.onrender.com/ws

# Supabase Client SDK (set actual values in Vercel environment variables)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Disable dev auth in production — require real Supabase tokens
NEXT_PUBLIC_ENABLE_DEV_AUTH=false
